            <column caption='Total Sales per customer' datatype='real' default-format='n&quot;$&quot;0;-&quot;$&quot;0' name='[Calculation_526639732114665493]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='SUM({[Calculation_526639732114219027]})' />
