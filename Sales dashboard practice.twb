          <datasource-dependencies datasource='federated.1p7yrtj1la22ms19r9bfk1qrfo7u'>
            <column caption='PY Customer' datatype='string' name='[CY Customer (copy)_526639732023586822]' role='dimension' type='nominal'>
              <calculation class='tableau' formula='IF  YEAR([Order Date]) = [Parameters].[Parameter 1]-1 THEN [Customer ID]&#13;&#10;END' />
            </column>
            <column caption='PY Sales' datatype='real' default-format='n&quot;$&quot;0,K;-&quot;$&quot;0,K' name='[CY Sales (copy)_454300661922516993]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='if YEAR([Order Date]) = [Parameters].[Parameter 1]-1 THEN [Sales]&#13;&#10;END' />
            </column>
            <column caption='CY Sales' datatype='real' default-format='n&quot;$&quot;0,K;-&quot;$&quot;0,K' name='[Calculation_454300661922189312]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='if YEAR([Order Date]) = [Parameters].[Parameter 1] THEN [Sales]&#13;&#10;END' />
            </column>
            <column aggregation='Sum' caption='Current Year' datatype='integer' default-format='n0;-0' name='[Calculation_454300661938458633]' role='dimension' type='ordinal'>
              <calculation class='tableau' formula='[Parameters].[Parameter 1]' />
            </column>
            <column aggregation='Sum' caption='Previous Year' datatype='integer' default-format='n0;-0' name='[Calculation_454300661938716682]' role='dimension' type='ordinal'>
              <calculation class='tableau' formula='[Calculation_454300661938458633]-1' />
            </column>
            <column caption='CY Customer' datatype='string' name='[Calculation_526639732023373829]' role='dimension' type='nominal'>
              <calculation class='tableau' formula='IF  YEAR([Order Date]) = [Parameters].[Parameter 1] THEN [Customer ID]&#13;&#10;END' />
            </column>
            <column caption='CY sales per customer' datatype='real' default-format='n&quot;$&quot;0;-&quot;$&quot;0' name='[Calculation_526639732114219027]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='SUM([Calculation_454300661922189312])/COUNTD([Calculation_526639732023373829])' />
            </column>
            <column caption='PY sales per customer' datatype='real' default-format='n&quot;$&quot;0;-&quot;$&quot;0' name='[Calculation_526639732114477076]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='SUM([CY Sales (copy)_454300661922516993])/COUNTD([CY Customer (copy)_526639732023586822])' />
