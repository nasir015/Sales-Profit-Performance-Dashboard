              </calculation>
            </column>
            <column caption='Total sales' datatype='real' default-format='n&quot;$&quot;0,K;-&quot;$&quot;0,K' name='[Calculation_454300661929222150]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='SUM({SUM([Calculation_454300661922189312])})' />
            </column>
