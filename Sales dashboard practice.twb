          <datasource-dependencies datasource='federated.1p7yrtj1la22ms19r9bfk1qrfo7u'>
            <column caption='PY Sales' datatype='real' default-format='n&quot;$&quot;0,K;-&quot;$&quot;0,K' name='[CY Sales (copy)_454300661922516993]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='if YEAR([Order Date]) = [Parameters].[Parameter 1]-1 THEN [Sales]&#13;&#10;END' />
            </column>
            <column caption='CY Sales' datatype='real' default-format='n&quot;$&quot;0,K;-&quot;$&quot;0,K' name='[Calculation_454300661922189312]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='if YEAR([Order Date]) = [Parameters].[Parameter 1] THEN [Sales]&#13;&#10;END' />
            </column>
            <column caption='% difference_sales' datatype='real' default-format='*▲ 0.0%; ▼ -0.0%;' name='[Calculation_454300661923373058]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='(SUM([Calculation_454300661922189312]) - SUM([CY Sales (copy)_454300661922516993]))/SUM([CY Sales (copy)_454300661922516993])' />
            </column>
            <column caption='Max/Min Sales' datatype='real' default-format='n&quot;$&quot;0,K;-&quot;$&quot;0,K' name='[Calculation_454300661926895619]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='if SUM([Calculation_454300661922189312]) = WINDOW_MAX(SUM([Calculation_454300661922189312]))&#13;&#10;THEN SUM([Calculation_454300661922189312])&#13;&#10;ELSEIF SUM([Calculation_454300661922189312]) = WINDOW_MIN(SUM([Calculation_454300661922189312]))&#13;&#10;THEN SUM([Calculation_454300661922189312])&#13;&#10;END'>
